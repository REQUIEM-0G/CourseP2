# =================================================================
# Конфігурація системи розпізнавання цифр (Digit Recognition System)
# =================================================================

# шлях до артефакту моделі (mnist_model.h5) 
MODEL_PATH=mnist_model.h5

# рівень логування (DEBUG, INFO, WARNING, ERROR)
# DEBUG - для розробки, INFO - для продуктового середовища
LOG_LEVEL=INFO

# налаштування мережі
SERVER_PORT=8501

# налаштування Streamlit

# обмеження розміру завантажуваного файлу в Мб (захист від DoS-атак)
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=5

# запуск без автоматичного відкриття браузера (true для Docker/CI)
STREAMLIT_SERVER_HEADLESS=true

# адреса сервера (0.0.0.0 для доступу ззовні контейнера)
STREAMLIT_SERVER_ADDRESS=0.0.0.0